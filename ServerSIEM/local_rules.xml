<!-- ================= LOCAL RULES ================= -->

<!-- SSH -->
<group name="local,syslog,sshd,">
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>
</group>

<!-- CERBOS -->
<group name="cerbos,">
  <rule id="100100" level="5">
    <decoded_as>json</decoded_as>
    <match>"effect":"EFFECT_ALLOW"</match>
    <description>Cerbos ALLOW access</description>
  </rule>
  <rule id="100101" level="10">
    <decoded_as>json</decoded_as>
    <match>"effect":"EFFECT_DENY"</match>
    <description>Cerbos DENY access</description>
  </rule>
</group>

<!-- NGINX -->
<group name="nginx,web,attack,">
  <rule id="100300" level="3">
    <decoded_as>json</decoded_as>
    <match>"remote_addr"</match>
    <description>Nginx access log detected</description>
  </rule>
  <rule id="100301" level="7">
    <if_sid>100300</if_sid>
    <match>"status":403</match>
    <field name="data.uri">!^/favicon.ico$</field>
    <description>Nginx 403 Forbidden</description>
    <group>web,access_denied,</group>
  </rule>
  <rule id="100302" level="10">
    <if_sid>100300</if_sid>
    <match>"status":429</match>
    <description>Nginx rate limit triggered</description>
    <group>dos,attack,</group>
  </rule>
  <rule id="100303" level="8">
    <if_sid>100300</if_sid>
    <match>"status":5</match>
    <description>Nginx server error (5xx)</description>
    <group>web,error,</group>
  </rule>
  <rule id="100304" level="12" frequency="20" timeframe="30">
    <if_matched_sid>100300</if_matched_sid>
    <same_field>remote_addr</same_field>
    <description>High request rate from single IP</description>
  </rule>
  <rule id="100305" level="0">
    <if_sid>100300</if_sid>
    <field name="data.uri">^/favicon.ico$</field>
    <description>Ignore favicon.ico</description>
  </rule>
</group>

<!-- KEYCLOAK -->
<group name="keycloak,authentication,iam,">
  <rule id="100400" level="5">
    <decoded_as>json</decoded_as>
    <match>\"type\":\"LOGIN\"</match>
    <description>Keycloak login success</description>
    <group>authentication_success,iam,</group>
  </rule>
  <rule id="100401" level="10">
    <decoded_as>json</decoded_as>
    <match>\"type\":\"LOGIN_ERROR\"</match>
    <description>Keycloak login failed</description>
    <group>authentication_failed,security,</group>
  </rule>
  <rule id="100402" level="3">
    <decoded_as>json</decoded_as>
    <match>\"type\":\"LOGOUT\"</match>
    <description>Keycloak logout</description>
    <group>session,</group>
  </rule>
  <rule id="100403" level="5">
    <decoded_as>json</decoded_as>
    <match>\"type\":\"UPDATE_PASSWORD\"</match>
    <description>Keycloak password updated</description>
    <group>account_management,</group>
  </rule>
  <rule id="100404" level="9">
    <decoded_as>json</decoded_as>
    <match>\"type\":\"UPDATE_PASSWORD_ERROR\"</match>
    <description>Keycloak password update failed</description>
    <group>account_management,security,</group>
  </rule>
  <rule id="100410" level="15" frequency="5" timeframe="60">
    <if_matched_sid>100401</if_matched_sid>
    <same_field>data.ipAddress</same_field>
    <description>Brute force attack detected on Keycloak (5 fails / 60s)</description>
    <group>attack,bruteforce,security,</group>
  </rule>
</group>
<!-- RESOURCES APP -->
<group name="resources_app,audit,">

  <rule id="100500" level="3">
    <decoded_as>json</decoded_as>
    <match>"source":"resources_app"</match>
    <description>Resources App audit log</description>
  </rule>

  <rule id="100501" level="3">
    <if_sid>100500</if_sid>
    <field name="data.action">upload_document</field>
    <field name="data.result">success</field>
    <description>Document uploaded: $(data.resource) by $(data.user.name)</description>
  </rule>

  <rule id="100502" level="3">
    <if_sid>100500</if_sid>
    <field name="data.action">download_document</field>
    <field name="data.result">success</field>
    <description>Document downloaded: $(data.resource) by $(data.user.name)</description>
  </rule>

  <rule id="100503" level="8">
    <if_sid>100500</if_sid>
    <field name="data.action">delete_document</field>
    <field name="data.result">success</field>
    <description>Document DELETED: $(data.resource) by $(data.user.name)</description>
  </rule>

  <rule id="100504" level="6">
    <if_sid>100500</if_sid>
    <field name="data.result">denied</field>
    <description>Permission denied: $(data.action) by $(data.user.name)</description>
  </rule>

  <rule id="100505" level="4">
    <if_sid>100500</if_sid>
    <field name="data.result">failure</field>
    <description>Action failed: $(data.action) by $(data.user.name)</description>
  </rule>

  <rule id="100506" level="10" frequency="3" timeframe="60">
    <if_matched_sid>100504</if_matched_sid>
    <same_field>user.name</same_field>
    <description>ALERT: Multiple permission denials by $(user.name)</description>
  </rule>

  <rule id="100507" level="10" frequency="5" timeframe="60">
    <if_matched_sid>100503</if_matched_sid>
    <same_field>user.name</same_field>
    <description>CRITICAL: Mass deletion by $(user.name)</description>
  </rule>
</group>


<group name="private_app,audit,">

  <rule id="100599" level="3">
    <decoded_as>json</decoded_as>
    <match>"action":"</match>
    <description>Private app audit log base rule</description>
  </rule>

  <rule id="100600" level="7">
    <if_sid>100599</if_sid>
    <match>"action":"UPDATE_TASK"</match>
    <description>Task updated by user $(data.user) from $(data.ip)</description>
    <group>audit,task_change,</group>
  </rule>

  <rule id="100601" level="10">
    <if_sid>100599</if_sid>
    <match>"action":"DELETE_TASK"</match>
    <description>Task deleted by user $(data.user) from $(data.ip)</description>
    <group>audit,task_delete,</group>
  </rule>

  <rule id="100602" level="7">
    <if_sid>100599</if_sid>
    <match>"action":"CREATE_TASK"</match>
    <description>Task created by user $(data.user) from $(data.ip)</description>
    <group>audit,task_create,</group>
  </rule>

  <rule id="100603" level="10">
    <if_sid>100599</if_sid>
    <match>"action":"DELETE_PROJECT"</match>
    <description>Project deleted by user $(data.user) from $(data.ip)</description>
    <group>audit,project_delete,</group>
  </rule>

  <rule id="100610" level="12" frequency="3" timeframe="60">
    <if_matched_sid>100601</if_matched_sid>
    <same_field>data.user</same_field>
    <description>CRITICAL: Mass task deletion by same user $(data.user)</description>
    <group>audit,attack,</group>
  </rule>

</group>
